pipeline {
    agent {
        docker {
            image 'vamshikrishnasiribommala/jenkins-maven-docker'
            args '-v /var/run/docker.sock:/var/run/docker.sock'
        }
    }

    stages {
        stage('Checkout') {
            steps {
                git branch: 'main', url: 'https://github.com/VamshiKrishnaSiribommala/Jenkins-Zero-To-Hero.git'
            }
        }

        stage('Build and Test') {
            steps {
                sh '''
                cd java-maven-sonar-argocd-helm-k8s/spring-boot-app
                mvn clean package
                '''
            }
        }

        stage('Static Code Analysis') {
            environment {
                SONAR_URL = "http://13.126.186.250:9000"
            }
            steps {
                withCredentials([string(credentialsId: 'sonarqube', variable: 'SONAR_TOKEN')]) {
                    sh '''
                    cd java-maven-sonar-argocd-helm-k8s/spring-boot-app
                    mvn sonar:sonar \
                    -Dsonar.host.url=$SONAR_URL \
                    -Dsonar.token=$SONAR_TOKEN
                    '''
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                sh '''
                cd java-maven-sonar-argocd-helm-k8s/spring-boot-app
                docker build -t vamshikrishnasiribommala/ultimate-cicd:${BUILD_NUMBER} .
                '''
            }
        }

        stage('Push Docker Image') {
            steps {
                script {
                    // This worked in Build #28! Keeping it as is.
                    docker.withRegistry('https://index.docker.io/v1/', 'docker-cred') {
                        docker.image("vamshikrishnasiribommala/ultimate-cicd:${env.BUILD_NUMBER}").push()
                    }
                }
            }
        }

        stage('Update Deployment File') {
            steps {
                withCredentials([string(credentialsId: 'github', variable: 'GITHUB_TOKEN')]) {
                    sh '''
                    # FIX: Removed --global. This writes to the local folder which we HAVE permission for.
                    git config user.email "devops@example.com"
                    git config user.name "DevOps"

                    # Updates the deployment manifest
                    sed -i "s/replaceImageTag/${BUILD_NUMBER}/g" java-maven-sonar-argocd-helm-k8s/spring-boot-app-manifests/deployment.yml

                    git add java-maven-sonar-argocd-helm-k8s/spring-boot-app-manifests/deployment.yml
                    git commit -m "Update image tag to ${BUILD_NUMBER}" || echo "No changes to commit"

                    # Pushes using the token
                    git push https://${GITHUB_TOKEN}@github.com/VamshiKrishnaSiribommala/Jenkins-Zero-To-Hero.git HEAD:main
                    '''
                }
            }
        }
    }
}
